# SPA fallback + basic hardening for the React build on Apache/cPanel.
# This file is copied verbatim into dist/ by Vite.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # SPA routes that collide with a real asset folder (e.g. /smm vs the /smm/videos
  # folder) must serve the app, not the directory. Sub-paths like
  # /smm/videos/x.mp4 don't match here and fall through to the file check below.
  RewriteRule ^smm/?$ index.html [L]

  # Don't rewrite real files/directories (assets, images, the API, the old admin).
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Leave the backend + existing panel out of the SPA fallback.
  RewriteRule ^(api|admin)(/|$) - [L]

  # Everything else -> let React Router handle the route.
  RewriteRule ^ index.html [L]
</IfModule>

# Cache hashed assets aggressively; never cache index.html.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpe?g|webp|avif|svg|gif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Gzip/deflate text assets when available.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
